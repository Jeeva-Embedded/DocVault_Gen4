{
  "name": "gen4-portal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "emulator": "firebase emulators:start --project demo-gen4portal",
    "dev": "concurrently -k -n \"EMULATOR,VITE\" -c \"yellow,cyan\" \"npm run emulator\" \"vite\"",
    "dev:noemulator": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "vite build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.5.0",
    "firebase": "^10.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.1.1",
    "libsodium-wrappers": "^0.8.4",
    "vite": "^5.2.0"
  }
}
